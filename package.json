{
  "name": "responsive-authentication-website",
  "version": "1.0.0",
  "description": "Full-stack responsive authentication website with Express backend, admin dashboard, and theme switching.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "set USE_HTTPS=true&& set API_BASE_URL=http://127.0.0.1:5000&& concurrently \"npm:server\" \"npm:client\" \"npm:open\"",
    "open": "node scripts/open-browser.js https://localhost:3000",
    "client": "npm --prefix authflow-next run dev",
    "client:vite": "vite --host 0.0.0.0 --open",
    "server": "node server.js",
    "build": "npm --prefix authflow-next run build && npm run build:vite",
    "build:vite": "vite build",
    "start": "node server.js",
    "preview": "npm run build && npm run start"
  },
  "devDependencies": {
    "vite": "^7.2.7"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "nodemailer": "^9.0.0",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4"
  }
}
