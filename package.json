{
  "name": "responsive-authentication-website",
  "version": "1.0.0",
  "description": "Full-stack responsive authentication website with Express backend, admin dashboard, and theme switching.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite --host 0.0.0.0",
    "server": "node server.js",
    "build": "vite build",
    "start": "node server.js",
    "preview": "npm run build && npm run start"
  },
  "devDependencies": {
    "vite": "^7.2.7"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4"
  }
}
